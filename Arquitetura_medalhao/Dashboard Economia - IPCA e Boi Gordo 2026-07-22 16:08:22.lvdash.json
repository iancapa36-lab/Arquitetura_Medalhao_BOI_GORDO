    {
      "name": "variacoes_2025",
      "displayName": "Variações 2025 - IPCA e Boi Gordo",
      "queryLines": [
        "SELECT\n",
        "  data,\n",
        "  'Variação IPCA' as indicador,\n",
        "  variacao_ipca as variacao\n",
        "FROM\n",
        "  workspace.gold_economia.vw_gold_dashboard\n",
        "WHERE\n",
        "  YEAR(data) = 2025\n",
        "  AND variacao_ipca IS NOT NULL\n",
        "UNION ALL\n",
        "SELECT\n",
        "  data,\n",
        "  'Variação Boi Gordo' as indicador,\n",
        "  variacao_boi as variacao\n",
        "FROM\n",
        "  workspace.gold_economia.vw_gold_dashboard\n",
        "WHERE\n",
        "  YEAR(data) = 2025\n",
        "  AND variacao_boi IS NOT NULL\n",
        "ORDER BY\n",
        "  data,\n",
        "  indicador"
      ]
    },
    {
      "name": "destaque_impacto",
      "displayName": "Destaque e Impacto",
      "queryLines": [
        "WITH base AS (\n",
        "  SELECT\n",
        "    data,\n",
        "    variacao_ipca,\n",
        "    variacao_boi,\n",
        "    ABS(variacao_ipca - variacao_boi) AS diferenca_abs\n",
        "  FROM\n",
        "    workspace.gold_economia.vw_gold_dashboard\n",
        "),\n",
        "limiar AS (\n",
        "  SELECT\n",
        "    PERCENTILE_APPROX(diferenca_abs, 0.5) AS mediana\n",
        "  FROM\n",
        "    base\n",
        ")\n",
        "SELECT\n",
        "  b.data,\n",
        "  b.variacao_ipca,\n",
        "  b.variacao_boi,\n",
        "  b.diferenca_abs,\n",
        "  CASE\n",
        "    WHEN b.diferenca_abs <= l.mediana THEN 'Empate'\n",
        "    WHEN b.variacao_ipca > b.variacao_boi THEN 'Inflação cresce mais'\n",
        "    ELSE 'Preço do boi cresce mais'\n",
        "  END AS destaque,\n",
        "  CASE\n",
        "    WHEN b.diferenca_abs <= l.mediana THEN 'Baixa divergência'\n",
        "    ELSE 'Alta divergência'\n",
        "  END AS classe_impacto\n",
        "FROM\n",
        "  base b CROSS JOIN limiar l\n",
        "ORDER BY\n",
        "  b.data DESC"
      ]
    }
