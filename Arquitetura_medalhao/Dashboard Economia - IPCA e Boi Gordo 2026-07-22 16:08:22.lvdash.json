          }
        ]
      }
    },
    {
      "name": "correlacao",
      "displayName": "Correlação IPCA e Boi",
      "queryLines": [
        "SELECT\n",
        "  CORR(variacao_ipca, variacao_boi) as correlacao\n",
        "FROM\n",
        "  workspace.gold_economia.vw_gold_dashboard\n",
        "WHERE\n",
        "  variacao_ipca IS NOT NULL\n",
        "  AND variacao_boi IS NOT NULL"
      ]
    },
